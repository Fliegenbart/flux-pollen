# PollenCast configuration (local development defaults)
# Copy to .env and replace placeholders before running.

# App
APP_NAME=PollenCast
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database
POSTGRES_USER=pollencast
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pollencast_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Security — MUST be replaced in any non-dev setup (>=32 random chars)
SECRET_KEY=generate-a-secure-random-key-here-minimum-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial admin account (alternative: AUTH_USER_REGISTRY_JSON)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password-min-12-chars

# Machine-to-machine API key for customer integrations
M2M_SECRET_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Data sources
DWD_POLLEN_URL=https://opendata.dwd.de/climate_environment/health/alerts/s31fg.json
OPENWEATHER_API_KEY=

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
